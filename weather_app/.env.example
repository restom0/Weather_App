# OpenWeather API key (get one free at https://openweathermap.org/api).
# This is read server-side only and is NEVER exposed to the browser.
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Rate limiting (optional — these are the defaults).
# Max requests allowed per IP per window, and the window length in milliseconds.
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
