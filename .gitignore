# Root-level ignores for the repository. The app has its own, more detailed
# .gitignore in weather_app/.

# Dependencies
node_modules/

# Build output & coverage
dist/
dist-ssr/
build/
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables — never commit real API keys
.env
.env.*
!.env.example

# Vercel
.vercel/

# OS & editor cruft
.DS_Store
Thumbs.db
*.swp
*.local
