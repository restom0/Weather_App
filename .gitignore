# Root-level ignores for the repository. The app has its own, more detailed
# .gitignore in weather_app/.

# Dependencies
node_modules/

# Build output & coverage
dist/
dist-ssr/
build/
coverage/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables — never commit real API keys
.env
.env.*
!.env.example

# Vercel
.vercel/

# SonarQube / SonarCloud scanner working directory
.scannerwork/

# Tool caches / local indexes
.eslintcache
.codegraph/

# OS & editor cruft
.DS_Store
Thumbs.db
*.swp
*.local

# IDE project config (machine-specific, not shared)
.idea/
.vscode/
!.vscode/extensions.json

# Local agent/tool settings
.claude/settings.local.json
.agents/
